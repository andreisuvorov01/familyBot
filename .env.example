# ============================================
# Family Bot Configuration
# Скопируйте в .env и заполните ВСЕ значения
# ============================================

# Telegram Bot (обязательно)
BOT_TOKEN=your_telegram_bot_token_here

# URL вашего приложения (обязательно)
WEBAPP_URL=https://your-domain.example.com

# Секретный ключ JWT (обязательно, минимум 32 символа)
# Генерация: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_long_random_string_min_32_chars

# PostgreSQL (обязательно)
POSTGRES_PASSWORD=replace_with_strong_password

# Redis (опционально, используется для rate limiting в multi-worker)
REDIS_PASSWORD=replace_with_redis_password

# SSL / Certbot (обязательно для HTTPS)
CERTBOT_EMAIL=your-email@example.com

# ============================================
# Опциональные настройки
# ============================================

# CORS — укажите домен вашего фронтенда через запятую
# Если не задано — CORS отключён (только same-origin)
ALLOWED_ORIGINS=https://your-domain.example.com

# JWT
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Scheduler
TIMEZONE=Europe/Moscow

# Monitoring
GRAFANA_PASSWORD=replace_with_grafana_password
# SENTRY_DSN=https://key@sentry.io/project

# Режим
DEBUG=false
ENVIRONMENT=production
