# ============================================
# Family Bot Configuration for Docker
# ============================================

# 🔐 ОБЯЗАТЕЛЬНЫЕ НАСТРОЙКИ (заполнить перед запуском)

# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here
WEBAPP_URL=https://my-family-tasks.duckdns.org

# Security
SECRET_KEY=your_very_secure_secret_key_change_this_in_production

# PostgreSQL Database
POSTGRES_PASSWORD=changeme123

# SSL Certificates
CERTBOT_EMAIL=your-email@example.com

# ============================================
# ОПЦИОНАЛЬНЫЕ НАСТРОЙКИ
# ============================================

# Database Configuration (автоматически настраивается в Docker)
# Для локальной разработки:
# DATABASE_URL=sqlite+aiosqlite:///./family_base.db
# Для Docker (PostgreSQL):
DATABASE_URL=postgresql+asyncpg://familyuser:${POSTGRES_PASSWORD}@postgres:5432/familybot

# Redis Configuration
REDIS_URL=redis://redis:6379/0
ENABLE_REDIS=true

# JWT Configuration
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60  # seconds

# Scheduler Configuration
TIMEZONE=Europe/Moscow
MORNING_NOTIFICATION_HOUR=9
MORNING_NOTIFICATION_MINUTE=0
DEADLINE_CHECK_INTERVAL=1  # minutes

# Logging
LOG_LEVEL=INFO
LOG_FILE=/app/logs/familybot.log
LOG_MAX_SIZE=10485760  # 10MB
LOG_BACKUP_COUNT=5

# Monitoring
SENTRY_DSN=your_sentry_dsn_here_optional
ENABLE_METRICS=true
PROMETHEUS_MULTIPROC_DIR=/tmp

# Grafana
GRAFANA_PASSWORD=admin123

# Application Settings
DEBUG=false
ENVIRONMENT=production
ALLOWED_ORIGINS=https://my-family-tasks.duckdns.org

# Docker specific
COMPOSE_PROJECT_NAME=familybot
COMPOSE_HTTP_TIMEOUT=300

# ============================================
# НАСТРОЙКИ ДЛЯ РАЗРАБОТКИ
# ============================================

# Раскомментируйте для разработки:
# DEBUG=true
# ENVIRONMENT=development
# DATABASE_URL=sqlite+aiosqlite:///./family_base.db
# ENABLE_REDIS=false
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,https://my-family-tasks.duckdns.org